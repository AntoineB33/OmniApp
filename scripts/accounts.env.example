# =====================================================================
#  accounts.env.example - template for scripts/accounts.env (gitignored).
#
#  Copy this file to "accounts.env" in the same folder and fill in the
#  three accounts' credentials. The account{1,2,3}-* scripts read it to
#  open the app already signed in / to empty an account's synced data.
#
#  Format: KEY=VALUE, one per line. No spaces around '='. No quotes (the
#  value is taken verbatim to end-of-line). Lines starting with '#' are
#  comments. Avoid '!' and '%' in passwords (cmd.exe expansion eats them).
#
#  The username is an arbitrary handle, NOT necessarily an email. Both the
#  app and account_db_admin.py turn "<user>" into "<user>@<LOGIN_DOMAIN>"
#  for Supabase (which authenticates by email). A value already containing
#  '@' is used as-is.
# =====================================================================

ACC1_USER=account1
ACC1_PASS=change-me-1

ACC2_USER=account2
ACC2_PASS=change-me-2

ACC3_USER=account3
ACC3_PASS=change-me-3

# Optional. Must match LOGIN_EMAIL_DOMAIN in shared StartupLogin.kt.
LOGIN_DOMAIN=omniapp.local

# Optional. Default to the public values baked into shared SupabaseConfig.kt;
# set only to point the scripts at a different Supabase project.
# SUPABASE_URL=https://itoaqbftjemovkzswiyu.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOi...
